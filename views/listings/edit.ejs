<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h2>Create New Listing</h2>
    <form method = "POST" action = "/listings/<%=listing._id%>?_method=PUT">
        <input name = "listing[title]"type="text" value = "<%=listing.title%>">
        <br>
        <br>
        <textarea name = "listing[description]" type = "text"  ><%=listing.description%></textarea>
        <br>
        <br>
        <input name = "listing[price]" type="text" value = "<%=listing.price%>">
        <br>
        <br>
        <input name = "listing[location]" type="text" value = "<%=listing.location%>">
        <br>
        <br>
        <input name = "listing[country]" type="text" value = "<%=listing.country%>">
        <br>
        <button>Update</button>
        </form>
</body>
</html>